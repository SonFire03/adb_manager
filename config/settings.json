{
  "app": {
    "name": "ADB Manager Pro",
    "language": "fr",
    "theme": "dark",
    "accent": "#99c1f1",
    "refresh_interval_ms": 2500,
    "safe_mode": true,
    "scrcpy_bin": "scrcpy",
    "adb_qr_tool": "adb-connect-qr"
  },
  "adb": {
    "binary": "adb",
    "default_timeout": 20,
    "auto_reconnect": true,
    "wifi_scan_ports": [
      5555,
      5556,
      5557
    ]
  },
  "backup": {
    "default_dir": "./backups",
    "compression": true
  },
  "logging": {
    "level": "INFO",
    "file": "adb_manager.log",
    "max_bytes": 1048576,
    "backup_count": 3
  },
  "ui": {
    "density": "comfortable",
    "command_root_filter": "Sans root",
    "command_search": "",
    "command_favorites_only": false,
    "sidebar_collapsed": false,
    "confirm_critical_commands": true,
    "logcat_auto_scroll": true,
    "batch_workers": 2,
    "batch_retry": 1,
    "batch_timeout_s": 120,
    "batch_stop_on_error": false
  },
  "remote": {
    "scrcpy_bitrate_m": 12,
    "scrcpy_max_size": 1280,
    "scrcpy_max_fps": 60,
    "scrcpy_no_audio": true,
    "scrcpy_fullscreen": false,
    "scrcpy_always_on_top": false,
    "scrcpy_turn_screen_off": false,
    "scrcpy_stay_awake": false,
    "scrcpy_show_touches": false,
    "scrcpy_no_control": false,
    "scrcpy_extra_args": ""
  }
}